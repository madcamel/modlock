#!/usr/bin/env python3
"""modlock: manage automatic kernel module loading."""

import argparse
import os
import re
import shutil
import subprocess
import sys

INSTALL_PATH    = "/usr/local/sbin/modlock"
SERVICE_NAME    = "modlock.service"
SERVICE_PATH    = f"/etc/systemd/system/{SERVICE_NAME}"
MODPROBE_CTL    = "/proc/sys/kernel/modprobe"
MODULES_FILE    = "/etc/modules"
DISABLE_VALUE   = "/bin/true"
MODPROBE_SEARCH = ("/usr/sbin/modprobe", "/sbin/modprobe")
MODULE_NAME_RE  = re.compile(r"^[A-Za-z0-9_-]{1,64}$")

SERVICE_UNIT = f"""\
[Unit]
Description=Disable automatic kernel module loading (modlock)
# Slot this service into early boot, immediately after systemd-modules-load.service
# finishes seeding modules from /etc/modules. We want to slam the autoload gate shut
# before udev / coldplug / late boot have a chance to request extra modules.
#
# DefaultDependencies=no   : opt out of the implicit After=basic.target that systemd
#                            adds to normal services; basic.target comes *after*
#                            sysinit.target, which would push us past the window we
#                            want to run in.
# After=systemd-modules-load.service
#                          : wait until /etc/modules has been processed, otherwise
#                            we'd disable modprobe before our own snapshot of
#                            modules gets loaded.
# Before=sysinit.target    : run as part of sysinit.target rather than after it.
# Conflicts/Before=shutdown.target
#                          : standard shutdown coordination, required once
#                            DefaultDependencies=no removes the implicit version.
DefaultDependencies=no
After=systemd-modules-load.service
Before=sysinit.target shutdown.target
Conflicts=shutdown.target

[Service]
# oneshot + RemainAfterExit so the unit reports "active" after the single
# /bin/true write to /proc/sys/kernel/modprobe completes.
Type=oneshot
ExecStart={INSTALL_PATH} --lock
RemainAfterExit=yes

[Install]
WantedBy=sysinit.target
"""


def die(msg, code=1):
    print(f"modlock: {msg}", file=sys.stderr)
    sys.exit(code)


def require_root():
    if os.geteuid() != 0:
        die("must be run as root")


def find_modprobe():
    for p in MODPROBE_SEARCH:
        if os.path.isfile(p):
            return p
    p = shutil.which("modprobe")
    if p:
        return p
    die("cannot locate modprobe binary")


def cmd_update():
    require_root()
    result = subprocess.run(
        ["lsmod"], capture_output=True, text=True, check=True
    )
    lines = result.stdout.splitlines()
    if lines and lines[0].startswith("Module"):
        lines = lines[1:]

    modules = []
    seen = set()
    for line in lines:
        line = line.strip()
        if not line:
            continue
        name = line.split()[0]
        if not MODULE_NAME_RE.match(name):
            print(f"modlock: skipping invalid module name: {name!r}",
                  file=sys.stderr)
            continue
        if name in seen:
            continue
        seen.add(name)
        modules.append(name)

    with open(MODULES_FILE, "w") as f:
        f.write("# Generated by modlock --update\n")
        for m in modules:
            f.write(m + "\n")
    os.chmod(MODULES_FILE, 0o644)
    print(f"wrote {len(modules)} module(s) to {MODULES_FILE}")


def cmd_lock():
    require_root()
    with open(MODPROBE_CTL, "w") as f:
        f.write(DISABLE_VALUE)
    print(f"locked: {MODPROBE_CTL} := {DISABLE_VALUE}")


def cmd_unlock():
    require_root()
    modprobe = find_modprobe()
    with open(MODPROBE_CTL, "w") as f:
        f.write(modprobe)
    print(f"unlocked: {MODPROBE_CTL} := {modprobe}")


def cmd_install():
    require_root()
    src = os.path.realpath(sys.argv[0])
    if not os.path.isfile(src):
        die(f"cannot locate running script at {src}")

    dst = os.path.realpath(INSTALL_PATH) if os.path.exists(INSTALL_PATH) else INSTALL_PATH
    if src != dst:
        os.makedirs(os.path.dirname(INSTALL_PATH), exist_ok=True)
        shutil.copyfile(src, INSTALL_PATH)
        os.chmod(INSTALL_PATH, 0o755)
        print(f"installed modlock to {INSTALL_PATH}")
    else:
        print(f"modlock already at {INSTALL_PATH}")

    with open(SERVICE_PATH, "w") as f:
        f.write(SERVICE_UNIT)
    os.chmod(SERVICE_PATH, 0o644)
    print(f"wrote unit file {SERVICE_PATH}")

    subprocess.run(["systemctl", "daemon-reload"], check=True)
    subprocess.run(["systemctl", "enable", SERVICE_NAME], check=True)
    print(f"enabled {SERVICE_NAME}")
    print()
    print("the service will gate autoloading off at next boot.")
    print("you probably want to run `modlock --lock` now to gate it off immediately.")


def cmd_uninstall():
    require_root()
    if os.path.isfile(SERVICE_PATH):
        subprocess.run(["systemctl", "disable", SERVICE_NAME], check=False)
        subprocess.run(["systemctl", "stop", SERVICE_NAME], check=False)
        os.unlink(SERVICE_PATH)
        subprocess.run(["systemctl", "daemon-reload"], check=True)
        print(f"removed {SERVICE_PATH}")
    else:
        print(f"no unit file at {SERVICE_PATH}")
    if os.path.exists(INSTALL_PATH):
        print(f"note: {INSTALL_PATH} not removed; rm it manually if desired")
    print()
    print("autoloading is still gated off in the running kernel.")
    print("you probably want to run `modlock --unlock` now to restore it.")


def main():
    p = argparse.ArgumentParser(
        prog="modlock",
        description="Manage automatic kernel module loading.",
    )
    g = p.add_mutually_exclusive_group(required=True)
    g.add_argument("--update",    action="store_true",
                   help="write currently-loaded modules to /etc/modules")
    g.add_argument("--lock",      action="store_true",
                   help="lock automatic module loading off")
    g.add_argument("--unlock",    action="store_true",
                   help="unlock automatic module loading")
    g.add_argument("--install",   action="store_true",
                   help=f"copy this script to {INSTALL_PATH} and install+enable {SERVICE_NAME}")
    g.add_argument("--uninstall", action="store_true",
                   help=f"remove {SERVICE_NAME} (does not delete {INSTALL_PATH})")
    args = p.parse_args()

    if   args.update:    cmd_update()
    elif args.lock:      cmd_lock()
    elif args.unlock:    cmd_unlock()
    elif args.install:   cmd_install()
    elif args.uninstall: cmd_uninstall()


if __name__ == "__main__":
    main()
